<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Color x:Key="Black">#000000</Color>
    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="OffBlack">#1F1F1F</Color>

    <Color x:Key="Gray200">#C8C8C8</Color>
    <Color x:Key="Gray300">#B0B0B0</Color>
    <Color x:Key="Gray600">#6E6E6E</Color>
    <Color x:Key="Gray900">#2B2B2B</Color>

    <Color x:Key="LightBg">#EFE9F8</Color>
    <Color x:Key="DarkBg">#121212</Color>
    <Color x:Key="LightText">#2D2144</Color>
    <Color x:Key="DarkText">#FFFFFF</Color>
    <Color x:Key="Primary">#512BD4</Color>
    <Color x:Key="PrimaryDark">#3E1FA8</Color>
    <Color x:Key="PrimaryDarkText">#FFFFFF</Color>
    <Color x:Key="DarkSurface">#1F1F1F</Color>

    <SolidColorBrush x:Key="BackgroundBrush" 
                     Color="{AppThemeBinding Light={StaticResource LightBg}, Dark={StaticResource DarkBg}}" />

    <SolidColorBrush x:Key="TextBrush" 
                     Color="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource DarkText}}" />

    <SolidColorBrush x:Key="SurfaceBrush" 
                     Color="{AppThemeBinding Light=White, Dark={StaticResource DarkSurface}}" />

</ResourceDictionary>