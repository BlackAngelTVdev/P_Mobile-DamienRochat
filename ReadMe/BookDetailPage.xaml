<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:ReadMe.Models"
             x:Class="ReadMe.BookDetailPage"
             Title="Détails"
             BackgroundColor="#EFE9F8">

    <ScrollView>
        <VerticalStackLayout Spacing="0">
            <!-- Header Section -->
            <Grid HeightRequest="250" BackgroundColor="#6A44A3">
                <Image Source="{Binding Book.Image}"
                       Aspect="AspectFill"
                       Opacity="0.6" />
                
                <VerticalStackLayout VerticalOptions="End" Padding="20" Spacing="5">
                    <Label Text="{Binding Book.Title}"
                           TextColor="White"
                           FontSize="24"
                           FontAttributes="Bold" />
                    <Label Text="{Binding Book.Author}"
                           TextColor="#DCCCF0"
                           FontSize="16" />
                </VerticalStackLayout>
            </Grid>

            <!-- Info Grid -->
            <Grid ColumnDefinitions="*,*,*" Padding="20" BackgroundColor="White">
                <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center">
                    <Label Text="Pages" FontSize="12" TextColor="#5E4E7B" HorizontalOptions="Center" />
                    <Label Text="{Binding Book.NbPages}" FontAttributes="Bold" TextColor="#23163B" HorizontalOptions="Center" />
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center">
                    <Label Text="Note" FontSize="12" TextColor="#5E4E7B" HorizontalOptions="Center" />
                    <Label Text="{Binding Book.AverageRate, StringFormat='{0:0.0}/5'}" FontAttributes="Bold" TextColor="#23163B" HorizontalOptions="Center" />
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center">
                    <Label Text="Publié" FontSize="12" TextColor="#5E4E7B" HorizontalOptions="Center" />
                    <Label Text="{Binding Book.Published}" FontAttributes="Bold" TextColor="#23163B" HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Grid>

            <VerticalStackLayout Padding="20" Spacing="15">
                <!-- Resume -->
                <Button Text="Voir le résumé (PDF)"
                        Clicked="OnViewPdfClicked"
                        BackgroundColor="#DCCCF0"
                        TextColor="#23163B"
                        CornerRadius="10"
                        HeightRequest="45" />

                <!-- Read Button -->
                <Button Text="Lire le livre"
                        Clicked="OnReadClicked"
                        BackgroundColor="#6A44A3"
                        TextColor="White"
                        CornerRadius="25"
                        HeightRequest="50"
                        Margin="0,10" />

                <!-- Comments Section -->
                <Label Text="Commentaires" FontSize="18" FontAttributes="Bold" TextColor="#23163B" Margin="0,10,0,0" />
                
                <CollectionView ItemsSource="{Binding Book.Comments}" SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:BookComment">
                            <Border Margin="0,0,0,10" Padding="15" BackgroundColor="White" StrokeThickness="0" StrokeShape="RoundRectangle 10">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="{Binding Title}" FontSize="14" TextColor="#23163B" FontAttributes="Bold" />
                                    <Label Text="Utilisateur anonyme" FontSize="12" TextColor="#5E4E7B" />
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- Add Comment -->
                <Label Text="Ajouter un avis" FontSize="16" FontAttributes="Bold" TextColor="#23163B" Margin="0,10,0,0" />
                
                <Entry x:Name="CommentEntry" Placeholder="Votre commentaire..." BackgroundColor="White" />
                
                <HorizontalStackLayout x:Name="StarRatingLayout" Spacing="4" Margin="0,10">
                    <Label Text="★" FontSize="32" TextColor="#6A44A3">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnStarTapped" CommandParameter="1" />
                        </Label.GestureRecognizers>
                    </Label>
                    <Label Text="★" FontSize="32" TextColor="#6A44A3">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnStarTapped" CommandParameter="2" />
                        </Label.GestureRecognizers>
                    </Label>
                    <Label Text="★" FontSize="32" TextColor="#6A44A3">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnStarTapped" CommandParameter="3" />
                        </Label.GestureRecognizers>
                    </Label>
                    <Label Text="★" FontSize="32" TextColor="#6A44A3">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnStarTapped" CommandParameter="4" />
                        </Label.GestureRecognizers>
                    </Label>
                    <Label Text="★" FontSize="32" TextColor="#6A44A3">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnStarTapped" CommandParameter="5" />
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>


                <Button Text="Envoyer mon avis"
                        Clicked="OnSubmitReviewClicked"
                        BackgroundColor="#DCCCF0"
                        TextColor="#23163B"
                        CornerRadius="25"
                        HeightRequest="45" />

                <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" Color="#6A44A3" />
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
