<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ReadMe.BookDetailPage"
             Title="Détails"
             BackgroundColor="#EFE9F8">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12">
            <Border HeightRequest="240"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 14"
                    BackgroundColor="#DCCCF0">
                <Image Source="{Binding Book.CoverImageUrl}"
                       Aspect="AspectFill" />
            </Border>

            <Label Text="{Binding Book.Title}"
                   FontSize="24"
                   FontAttributes="Bold"
                   TextColor="#23163B" />

            <Label Text="{Binding Book.Author}"
                   FontSize="14"
                   TextColor="#5E4E7B" />

            <Label Text="{Binding Book.SecondaryLine}"
                   FontSize="13"
                   TextColor="#6A44A3"
                   FontAttributes="Bold" />

            <Label Text="{Binding Book.DetailLine}"
                   FontSize="13"
                   TextColor="#6A44A3" />

            <Label Text="{Binding Book.UploadedLine}"
                   FontSize="12"
                   TextColor="#5E4E7B" />

            <BoxView HeightRequest="1" Color="#D8C8EA" />

            <Label Text="{Binding Book.DescriptionLine}"
                   FontSize="14"
                   TextColor="#2D2144"
                   LineBreakMode="WordWrap" />

            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="10">
                <VerticalStackLayout Grid.Row="0" Grid.Column="0" Spacing="2">
                    <Label Text="ISBN" FontSize="12" TextColor="#5E4E7B" />
                    <Label Text="{Binding Book.Isbn}" FontSize="13" FontAttributes="Bold" TextColor="#23163B" />
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Row="0" Grid.Column="1" Spacing="2">
                    <Label Text="Langue" FontSize="12" TextColor="#5E4E7B" />
                    <Label Text="{Binding Book.Language}" FontSize="13" FontAttributes="Bold" TextColor="#23163B" />
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Row="1" Grid.Column="0" Spacing="2">
                    <Label Text="Date de publication" FontSize="12" TextColor="#5E4E7B" />
                    <Label Text="{Binding Book.PublishDateText}" FontSize="13" FontAttributes="Bold" TextColor="#23163B" />
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Row="1" Grid.Column="1" Spacing="2">
                    <Label Text="Taille fichier" FontSize="12" TextColor="#5E4E7B" />
                    <Label Text="{Binding Book.DetailLine}" FontSize="13" FontAttributes="Bold" TextColor="#23163B" />
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Row="2" Grid.Column="0" Spacing="2">
                    <Label Text="Fichier EPUB" FontSize="12" TextColor="#5E4E7B" />
                    <Label Text="{Binding Book.EpubFilePath}" FontSize="13" FontAttributes="Bold" TextColor="#23163B" LineBreakMode="TailTruncation" />
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Row="2" Grid.Column="1" Spacing="2">
                    <Label Text="Ajouté le" FontSize="12" TextColor="#5E4E7B" />
                    <Label Text="{Binding Book.UploadedAt, StringFormat='{0:dd/MM/yyyy HH:mm}'}" FontSize="13" FontAttributes="Bold" TextColor="#23163B" />
                </VerticalStackLayout>
            </Grid>

            <Button Text="Lire le fichier EPUB"
                    Clicked="OnReadClicked"
                    BackgroundColor="#6A44A3"
                    TextColor="White"
                    CornerRadius="10"
                    HeightRequest="46"
                    Margin="0,10,0,0" />

            <Button Text="Supprimer ce livre"
                    Clicked="OnDeleteClicked"
                    BackgroundColor="#DCCCF0"
                    TextColor="#23163B"
                    CornerRadius="10"
                    HeightRequest="46" />

            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               Color="#6A44A3"
                               HorizontalOptions="Center"
                               Margin="0,8,0,0" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>