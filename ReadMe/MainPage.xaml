<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ReadMe.MainPage"
             Title="Accueil"
             BackgroundColor="#EFE9F8">

    <RefreshView IsRefreshing="{Binding IsRefreshing}" Refreshing="OnRefreshing">
        <Grid RowDefinitions="Auto,Auto,*" Padding="16,16,16,10">


            <CollectionView Grid.Row="2"
                            ItemsSource="{Binding Books}"
                            SelectionMode="Single"
                            SelectionChanged="OnSelectionChanged"
                            EmptyView="Aucun livre trouve.">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid RowDefinitions="Auto,Auto"
                              ColumnDefinitions="86,*"
                              Padding="0,8">
                            <Border Grid.Row="0"
                                    Grid.Column="0"
                                    HeightRequest="122"
                                    WidthRequest="82"
                                    BackgroundColor="#DCCCF0"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 8">
                                <Image Source="{Binding Image}" Aspect="AspectFill" />
                            </Border>

                            <VerticalStackLayout Grid.Row="0"
                                                 Grid.Column="1"
                                                 Spacing="4"
                                                 Padding="10,0,0,0">
                                <Label Text="{Binding Title}"
                                       FontSize="17"
                                       FontAttributes="Bold"
                                       TextColor="#23163B"
                                       LineBreakMode="TailTruncation" />

                                <Label Text="{Binding MetaLine}"
                                       FontSize="12"
                                       TextColor="#5E4E7B"
                                       LineBreakMode="TailTruncation" />

                                <Label Text="{Binding ExtraLine}"
                                       FontSize="12"
                                       TextColor="#5E4E7B"
                                       LineBreakMode="TailTruncation" />

                                <Label Text="{Binding ScoreLine}"
                                       FontSize="12"
                                       TextColor="#6A44A3"
                                       LineBreakMode="TailTruncation" />

                                <Label Text="{Binding CommentsCount, StringFormat='Commentaires: {0}'}"
                                       FontSize="12"
                                       TextColor="#6A44A3" />
                            </VerticalStackLayout>

                            <BoxView Grid.Row="1"
                                     Grid.ColumnSpan="2"
                                     Margin="0,10,0,0"
                                     HeightRequest="1"
                                     HorizontalOptions="Fill"
                                     Color="#D8C8EA" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <ActivityIndicator Grid.RowSpan="3"
                               IsVisible="{Binding IsRefreshing}"
                               IsRunning="{Binding IsRefreshing}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"
                               Color="#6B43AB" />
        </Grid>
    </RefreshView>

</ContentPage>
